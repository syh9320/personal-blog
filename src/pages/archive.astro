---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPostHref, getPublishedPosts } from "@/lib/content";

const posts = await getPublishedPosts();
const groupedPosts = posts.reduce<Record<string, typeof posts>>((groups, post) => {
  const year = String(post.data.pubDate.getFullYear());
  groups[year] ??= [];
  groups[year].push(post);
  return groups;
}, {});

const years = Object.keys(groupedPosts).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout title="Archive" description="按时间归档浏览文章">
  <section class="rounded-lg border border-border-soft bg-surface p-6 shadow-card">
    <p class="text-sm font-medium text-accent-strong">Archive</p>
    <h1 class="mt-3 text-3xl font-semibold text-text-primary">归档</h1>
    <p class="mt-3 text-sm leading-6 text-text-muted">按年份整理所有已发布文章。</p>
  </section>

  <section class="mt-8 space-y-6">
    {
      years.map((year) => (
        <div class="rounded-lg border border-border-soft bg-surface p-6 shadow-card">
          <h2 class="text-xl font-semibold text-text-primary">{year}</h2>
          <div class="mt-4 space-y-3">
            {groupedPosts[year].map((post) => (
              <a class="flex flex-col gap-1 rounded-lg border border-border-soft bg-surface-raised p-4 transition hover:border-border-strong hover:bg-accent-soft sm:flex-row sm:items-center sm:justify-between" href={getPostHref(post)}>
                <span class="font-medium text-text-primary">{post.data.title}</span>
                <span class="text-sm text-text-muted">{post.data.pubDate.toLocaleDateString("zh-CN")}</span>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </section>
</BaseLayout>
