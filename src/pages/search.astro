---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/PageHero.astro";
---

<BaseLayout title="Search" description="搜索博客文章和项目内容">
  <PageHero eyebrow="Search" title="搜索" description="使用静态索引搜索已发布文章和项目内容。生产构建后由 Pagefind 提供搜索能力，不需要后端服务。" />

  <section class="mt-8 rounded-lg border border-white/70 bg-surface/90 p-6 shadow-card backdrop-blur dark:border-white/10 dark:bg-surface/90">
    <label class="text-sm font-semibold text-text-primary" for="site-search">关键词</label>
    <input
      id="site-search"
      class="mt-3 w-full rounded-lg border border-border-soft bg-surface-raised px-4 py-3 text-base text-text-primary shadow-card outline-none transition placeholder:text-text-muted focus:border-accent"
      type="search"
      placeholder="搜索文章标题、摘要和正文"
      autocomplete="off"
      data-search-input
    />
    <p class="mt-3 text-sm text-text-muted" data-search-status>输入关键词开始搜索。</p>
    <div class="mt-6 space-y-3" data-search-results></div>
  </section>

  <script>
    const input = document.querySelector<HTMLInputElement>("[data-search-input]");
    const status = document.querySelector<HTMLElement>("[data-search-status]");
    const results = document.querySelector<HTMLElement>("[data-search-results]");

    let pagefind:
      | {
          search: (query: string) => Promise<{ results: Array<{ data: () => Promise<SearchResult> }> }>;
        }
      | undefined;

    type SearchResult = {
      url: string;
      meta: {
        title?: string;
      };
      excerpt?: string;
    };

    async function loadPagefind() {
      if (pagefind) return pagefind;

      try {
        const pagefindPath = "/pagefind/pagefind.js";
        pagefind = await import(/* @vite-ignore */ pagefindPath);
        return pagefind;
      } catch {
        status!.textContent = "搜索索引仅在生产构建后可用。请先运行 npm run build。";
      }
    }

    function renderEmpty(message: string) {
      if (!results || !status) return;

      status.textContent = message;
      results.innerHTML = "";
    }

    function escapeHtml(value: string) {
      return value.replace(/[&<>"']/g, (character) => {
        const entities: Record<string, string> = {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#039;",
        };

        return entities[character];
      });
    }

    input?.addEventListener("input", async () => {
      const query = input.value.trim();
      if (!query) {
        renderEmpty("输入关键词开始搜索。");
        return;
      }

      const search = await loadPagefind();
      if (!search || !results || !status) return;

      status.textContent = "搜索中...";
      const response = await search.search(query);
      const matches = await Promise.all(response.results.slice(0, 10).map((result) => result.data()));

      if (matches.length === 0) {
        renderEmpty("没有找到匹配结果。");
        return;
      }

      status.textContent = `找到 ${response.results.length} 个结果。`;
      results.innerHTML = matches
        .map(
          (match) => `
            <a class="block rounded-lg border border-white/70 bg-surface-raised p-4 shadow-card transition hover:border-accent hover:bg-accent-soft dark:border-white/10" href="${match.url}">
              <h2 class="text-base font-semibold text-text-primary">${escapeHtml(match.meta.title ?? match.url)}</h2>
              ${match.excerpt ? `<p class="mt-2 text-sm leading-6 text-text-muted">${match.excerpt}</p>` : ""}
            </a>
          `,
        )
        .join("");
    });
  </script>
</BaseLayout>
