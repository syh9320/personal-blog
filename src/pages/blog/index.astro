---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { getPublishedPosts } from "@/lib/content";

const posts = await getPublishedPosts();
---

<BaseLayout title="Blog" description="所有已发布文章">
  <section class="rounded-lg border border-border-soft bg-surface p-6 shadow-card">
    <p class="text-sm font-medium text-accent-strong">Blog</p>
    <h1 class="mt-3 text-3xl font-semibold text-text-primary">所有文章</h1>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-text-muted">这里收集所有已发布的文章，草稿会保留在内容目录中但不会出现在列表里。</p>
  </section>

  <section class="mt-8 grid gap-5 md:grid-cols-2">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
