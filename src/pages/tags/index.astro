---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllTags, getPostsByTag } from "@/lib/content";

const tags = await getAllTags();
const tagCounts = await Promise.all(tags.map(async (tag) => [tag, (await getPostsByTag(tag)).length] as const));
---

<BaseLayout title="Tags" description="按标签浏览文章">
  <section class="rounded-lg border border-border-soft bg-surface p-6 shadow-card">
    <p class="text-sm font-medium text-accent-strong">Tags</p>
    <h1 class="mt-3 text-3xl font-semibold text-text-primary">标签</h1>
    <p class="mt-3 text-sm leading-6 text-text-muted">用主题标签浏览已经发布的文章。</p>
  </section>

  <section class="mt-8 flex flex-wrap gap-3">
    {
      tagCounts.map(([tag, count]) => (
        <a class="rounded-lg border border-border-soft bg-surface-raised px-4 py-3 text-sm font-medium text-text-primary shadow-card transition hover:border-border-strong hover:bg-accent-soft" href={`/tags/${encodeURIComponent(tag)}/`}>
          {tag} <span class="text-text-muted">({count})</span>
        </a>
      ))
    }
  </section>
</BaseLayout>
