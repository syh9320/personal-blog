---
import type { BlogPost } from "@/lib/content";
import { getPostHref } from "@/lib/content";

type Props = {
  post: BlogPost;
};

const { post } = Astro.props;
const href = getPostHref(post);
const image = post.data.image;
---

<article class="group overflow-hidden rounded-lg border border-white/70 bg-surface/90 shadow-card backdrop-blur transition duration-200 hover:-translate-y-0.5 hover:border-accent hover:shadow-soft dark:border-white/10 dark:bg-surface/90">
  <a href={href} class:list={["grid h-full", image && "md:grid-cols-[minmax(0,1fr)_15rem]"]}>
    <div class="flex min-w-0 flex-col p-5">
      <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-text-muted">
        <span class="rounded-md bg-success-soft px-2 py-1 text-accent-strong">{post.data.pubDate.toLocaleDateString("zh-CN")}</span>
        <span>{post.data.tags.slice(0, 2).join(" / ")}</span>
      </div>
      <h2 class="mt-3 text-xl font-semibold leading-snug text-text-primary transition group-hover:text-accent-strong">{post.data.title}</h2>
      <p class="mt-3 line-clamp-2 text-sm leading-6 text-text-muted">{post.data.description}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {
          post.data.tags.map((tag) => (
            <span class="rounded-md bg-accent-soft px-2.5 py-1 text-xs font-medium text-accent-strong">
              #{tag}
            </span>
          ))
        }
      </div>
    </div>
    {
      image && (
        <div class="min-h-44 overflow-hidden border-t border-border-soft bg-accent-soft md:border-l md:border-t-0">
          <img class="h-full min-h-44 w-full object-cover transition duration-300 group-hover:scale-105" src={image} alt={post.data.title} loading="lazy" />
        </div>
      )
    }
  </a>
</article>
