---
import { siteConfig } from "@/config/site";

const tags = ["Astro", "MDX", "Design", "Projects"];
---

<aside class="rounded-lg border border-border-soft bg-surface p-6 shadow-card">
  <img class="h-16 w-16 rounded-lg border border-border-soft bg-accent-soft" src={siteConfig.author.avatar} alt="" />
  <h2 class="mt-4 text-lg font-semibold text-text-primary">{siteConfig.author.name}</h2>
  <p class="mt-2 text-sm leading-6 text-text-muted">{siteConfig.author.bio}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="rounded-md bg-accent-soft px-3 py-1 text-xs font-medium text-accent-strong">{tag}</span>
      ))
    }
  </div>
</aside>
