---
import { siteConfig } from "@/config/site";
import ThemeToggle from "@/components/ThemeToggle.astro";
---

<header class="sticky top-4 z-30 mx-auto w-full max-w-5xl rounded-lg border border-white/60 bg-surface/80 px-4 py-3 shadow-soft backdrop-blur-xl dark:border-white/10 dark:bg-surface/75">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <a href="/" class="flex items-center gap-3 text-sm font-semibold tracking-normal text-text-primary">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-accent-soft text-accent-strong shadow-card">OA</span>
      <span>{siteConfig.name}</span>
    </a>
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
      <nav class="flex flex-wrap items-center gap-1 text-sm font-medium text-text-muted" aria-label="Primary navigation">
        {
          siteConfig.nav.map((item) => (
            <a class="rounded-md px-3 py-2 transition hover:bg-accent-soft hover:text-text-primary" href={item.href}>
              {item.label}
            </a>
          ))
        }
      </nav>
      <ThemeToggle />
    </div>
  </div>
</header>
