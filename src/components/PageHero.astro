---
import { siteConfig } from "@/config/site";

type Props = {
  eyebrow: string;
  title: string;
  description: string;
};

const { eyebrow, title, description } = Astro.props;
---

<section class="relative overflow-hidden rounded-lg border border-white/70 bg-surface p-6 shadow-soft dark:border-white/10 sm:p-8">
  <div class="absolute inset-0 opacity-[0.14]">
    <img class="h-full w-full object-cover" src={siteConfig.hero.image} alt="" />
  </div>
  <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/95 to-surface/75"></div>
  <div class="relative">
    <p class="text-sm font-semibold text-accent-strong">{eyebrow}</p>
    <h1 class="mt-3 text-3xl font-semibold text-text-primary sm:text-4xl">{title}</h1>
    <p class="mt-4 max-w-2xl text-sm leading-7 text-text-muted">{description}</p>
  </div>
</section>
