---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Comments from "@/components/comments/Comments.astro";
import type { BlogPost } from "@/lib/content";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  post: BlogPost;
  headings: Heading[];
};

const { post, headings } = Astro.props;
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const image = post.data.image;
---

<BaseLayout title={post.data.title} description={post.data.description} image={image}>
  <article class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_16rem]">
    <div class="min-w-0 overflow-hidden rounded-lg border border-white/70 bg-surface/95 shadow-card backdrop-blur dark:border-white/10 dark:bg-surface/90">
      {
        image && (
          <div class="relative min-h-72 overflow-hidden border-b border-border-soft">
            <img class="absolute inset-0 h-full w-full object-cover" src={image} alt={post.data.title} />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="relative flex min-h-72 items-end p-6 sm:p-8">
              <div class="max-w-3xl text-white drop-shadow">
                <p class="text-sm font-semibold text-cyan-100">{post.data.pubDate.toLocaleDateString("zh-CN")}</p>
                <h1 class="mt-3 text-3xl font-semibold tracking-normal sm:text-5xl">{post.data.title}</h1>
                <p class="mt-4 text-base leading-8 text-white/90">{post.data.description}</p>
              </div>
            </div>
          </div>
        )
      }

      <header class:list={["border-b border-border-soft p-6 sm:p-8", image && "pt-7"]}>
        {!image && <p class="text-sm font-medium text-accent-strong">{post.data.pubDate.toLocaleDateString("zh-CN")}</p>}
        {!image && <h1 class="mt-3 text-3xl font-semibold tracking-normal text-text-primary sm:text-4xl">{post.data.title}</h1>}
        {!image && <p class="mt-4 text-base leading-8 text-text-muted">{post.data.description}</p>}
        {post.data.updatedDate && <p class="mt-3 text-sm text-text-muted">更新于 {post.data.updatedDate.toLocaleDateString("zh-CN")}</p>}
        <div class="mt-5 flex flex-wrap gap-2">
          {
            post.data.tags.map((tag) => (
              <a class="rounded-md bg-accent-soft px-2.5 py-1 text-xs font-medium text-accent-strong transition hover:bg-success-soft" href={`/tags/${encodeURIComponent(tag)}/`}>
                #{tag}
              </a>
            ))
          }
        </div>
      </header>
      <div class="prose prose-slate max-w-none p-6 dark:prose-invert prose-headings:tracking-normal prose-a:text-accent-strong prose-pre:border prose-pre:border-border-soft prose-pre:bg-[#0f172a] prose-pre:shadow-card sm:p-8">
        <slot />
      </div>
      <Comments />
    </div>

    <aside class="lg:sticky lg:top-28 lg:self-start">
      <div class="rounded-lg border border-white/70 bg-surface/90 p-5 shadow-card backdrop-blur dark:border-white/10 dark:bg-surface/90">
        <h2 class="text-sm font-semibold text-text-primary">目录</h2>
        {
          toc.length > 0 ? (
            <nav class="mt-4 space-y-2 text-sm text-text-muted" aria-label="Table of contents">
              {toc.map((heading) => (
                <a class:list={["block rounded-md px-2 py-1 transition hover:bg-accent-soft hover:text-text-primary", heading.depth === 3 && "pl-5"]} href={`#${heading.slug}`}>
                  {heading.text}
                </a>
              ))}
            </nav>
          ) : (
            <p class="mt-3 text-sm text-text-muted">这篇文章暂无目录。</p>
          )
        }
      </div>
    </aside>
  </article>
</BaseLayout>
